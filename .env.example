# .env.example
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================================
# LLM API Configuration (Groq)
# ============================================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# ============================================================
# Database Configuration (Optional)
# ============================================================
# PostgreSQL database for storing validation results
# If not configured, results will not be saved to database
DB_NAME=causal_guard
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost

# ============================================================
# Model Configuration (Optional)
# ============================================================
# Default model to use (leave commented to use default)
# GROQ_MODEL=llama-3.3-70b-versatile